# Captionaut environment variables.
#
# Copy this file to .env if you want to override defaults. Nothing in here is
# required for local development - the bootstrap script will work without it.
# .env is gitignored.

# Where the backend stores uploaded videos, burned outputs, and the denoised
# audio cache. Defaults to backend/ in dev, or ~/.captionaut when running from
# a packaged build.
# CAPTIONAUT_DATA_DIR=/path/to/data

# Override the ffmpeg binary used by the burn-in stage. By default, the backend
# looks for `ffmpeg` on PATH. Set this when shipping a bundled ffmpeg next to
# the app.
# FFMPEG_BIN=/usr/local/bin/ffmpeg

# HuggingFace access token, used for pyannote.audio model downloads.
# This is only read by Docker / CI workflows. For local dev the token is
# entered through the Settings panel in the UI and stored in localStorage.
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
