{
  "name": "captionaut",
  "private": true,
  "version": "0.1.0",
  "description": "Subtitles at light speed",
  "author": "catherinepereira",
  "license": "MIT",
  "main": "electron/dist/main.js",
  "scripts": {
    "dev:electron": "npm run build:electron && concurrently -k -n vite,electron \"npm:dev:vite\" \"wait-on http://localhost:5200 && node electron/scripts/run-dev.mjs\"",
    "dev:electron:shell": "npm run build:electron && wait-on http://localhost:5200 && node electron/scripts/run-dev.mjs",
    "dev:vite": "npm --prefix frontend run dev",
    "build:electron": "tsc -p electron",
    "build:frontend": "npm --prefix frontend run build",
    "build:backend": "python -m PyInstaller backend/captionaut.spec --clean --noconfirm",
    "build:all": "npm run build:electron && npm run build:frontend && npm run build:backend",
    "pack": "npm run build:electron && npm run build:frontend && electron-builder",
    "pack:win": "npm run build:electron && npm run build:frontend && electron-builder --win",
    "pack:mac": "npm run build:electron && npm run build:frontend && electron-builder --mac",
    "pack:linux": "npm run build:electron && npm run build:frontend && electron-builder --linux",
    "dist": "npm run build:all && electron-builder",
    "dist:win": "npm run build:all && electron-builder --win",
    "dist:mac": "npm run build:all && electron-builder --mac",
    "dist:linux": "npm run build:all && electron-builder --linux",
    "typecheck": "cd frontend && tsc --noEmit && cd .. && tsc -p electron --noEmit"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "cross-env": "^10.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.6.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.catherinepereira.captionaut",
    "productName": "Captionaut",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/dist/**/*",
      "frontend/dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist/captionaut-backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "zip"
      ],
      "icon": "electron/resources/icon.ico",
      "signAndEditExecutable": false,
      "signtoolOptions": {
        "signingHashAlgorithms": null
      },
      "extraResources": [
        {
          "from": "electron/resources/ffmpeg/win",
          "to": "ffmpeg",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "electron/resources/icon.icns",
      "category": "public.app-category.video",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "extraResources": [
        {
          "from": "electron/resources/ffmpeg/mac",
          "to": "ffmpeg",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "electron/resources/icon.png",
      "category": "AudioVideo",
      "extraResources": [
        {
          "from": "electron/resources/ffmpeg/linux",
          "to": "ffmpeg",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "nsisWeb": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
